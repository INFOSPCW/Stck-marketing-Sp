<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <!--
    Replace the apps dropdown div in the navbar (desktop) with a plain
    button that calls openHomeDashboard() — injected by navbar_patch.js.
    The method is on the NavBar component instance, which owns this template.
  -->
  <t t-name="odoo_home_dashboard.NavBar.AppsMenu.Desktop"
     t-inherit="web.NavBar.AppsMenu"
     t-inherit-mode="extension">

    <xpath expr="//div[hasclass('o_navbar_apps_menu')]" position="replace">
      <div class="o_navbar_apps_menu">
        <button
          data-hotkey="h"
          title="Home Dashboard"
          t-on-click="openHomeDashboard"
        >
          <i class="oi oi-apps"/>
        </button>
      </div>
    </xpath>

  </t>

</templates>
