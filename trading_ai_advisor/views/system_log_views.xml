<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ══ LIST VIEW ══ -->
  <record id="view_system_log_list" model="ir.ui.view">
    <field name="name">trading.system_log.list</field>
    <field name="model">trading.system_log</field>
    <field name="arch" type="xml">
      <list string="System Log"
            default_order="create_date desc"
            decoration-danger="level == 'error'"
            decoration-warning="level == 'warning'"
            decoration-success="level == 'success'"
            decoration-muted="level == 'info'">
        <field name="create_date" string="Time" readonly="1"/>
        <field name="level"    widget="badge"
               decoration-danger="level == 'error'"
               decoration-warning="level == 'warning'"
               decoration-success="level == 'success'"
               decoration-info="level == 'info'"/>
        <field name="category" widget="badge"/>
        <field name="instrument" optional="show"/>
        <field name="message"/>
        <field name="detail" optional="hide"/>
      </list>
    </field>
  </record>

  <!-- ══ FORM VIEW ══ -->
  <record id="view_system_log_form" model="ir.ui.view">
    <field name="name">trading.system_log.form</field>
    <field name="model">trading.system_log</field>
    <field name="arch" type="xml">
      <form string="Log Entry">
        <sheet>
          <group>
            <group>
              <field name="create_date" readonly="1"/>
              <field name="level"    widget="badge"/>
              <field name="category" widget="badge"/>
              <field name="instrument" readonly="1"/>
            </group>
            <group>
              <field name="message" readonly="1"/>
            </group>
          </group>
          <group string="Detail" invisible="not detail">
            <field name="detail" widget="text" readonly="1" nolabel="1"
                   colspan="2"
                   style="font-family:monospace;font-size:12px;white-space:pre-wrap;
                          background:var(--color-background-secondary);padding:12px;
                          border-radius:6px;min-height:80px;"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ══ SEARCH VIEW ══ -->
  <record id="view_system_log_search" model="ir.ui.view">
    <field name="name">trading.system_log.search</field>
    <field name="model">trading.system_log</field>
    <field name="arch" type="xml">
      <search string="Search Logs">
        <field name="message"/>
        <field name="instrument"/>
        <field name="detail"/>
        <separator/>
        <filter string="❌ Errors"   name="errors"   domain="[('level','=','error')]"/>
        <filter string="⚠ Warnings" name="warnings" domain="[('level','=','warning')]"/>
        <filter string="✅ Success"  name="success"  domain="[('level','=','success')]"/>
        <separator/>
        <filter string="💰 Price"     name="price"     domain="[('category','=','price')]"/>
        <filter string="📈 Positions" name="positions" domain="[('category','=','position')]"/>
        <filter string="🤖 Analysis"  name="analysis"  domain="[('category','=','analysis')]"/>
        <filter string="🧠 Learning"  name="learning"  domain="[('category','=','learning')]"/>
        <filter string="⚙ Automation" name="automation" domain="[('category','=','automation')]"/>
        <separator/>
        <filter string="Today" name="today"
                domain="[('create_date','&gt;=',datetime.datetime.now().strftime('%Y-%m-%d 00:00:00'))]"/>
        <filter string="This Week" name="week"
                domain="[('create_date','&gt;=',(datetime.datetime.now()-datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
        <separator/>
        <filter string="Group By: Level"    name="by_level"    context="{'group_by':'level'}"/>
        <filter string="Group By: Category" name="by_category" context="{'group_by':'category'}"/>
        <filter string="Group By: Date"     name="by_date"     context="{'group_by':'create_date:day'}"/>
      </search>
    </field>
  </record>

  <!-- ══ ACTION ══ -->
  <record id="action_system_log" model="ir.actions.act_window">
    <field name="name">System Log</field>
    <field name="res_model">trading.system_log</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_system_log_search"/>
    <field name="context">{"search_default_errors": 0}</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">No log entries yet</p>
      <p>System events will appear here once the module starts running:
         price fetches, position opens/closes, analysis sessions,
         price sanity failures, slippage warnings.</p>
    </field>
  </record>

</odoo>
