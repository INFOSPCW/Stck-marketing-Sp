<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- ═══════════════════════════════════════════════════════════════════
         FULL SCAN — every 3 hours, all 44 instruments
         Replaces all session-specific analysis crons below.
    ════════════════════════════════════════════════════════════════════════ -->
    <record id="cron_full_scan" model="ir.cron">
      <field name="name">Trading AI: Full Scan (every 3 hours)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_full_scan()</field>
      <field name="interval_number">3</field>
      <field name="interval_type">hours</field>
      <field name="active">True</field>
      <field name="nextcall">2026-05-20 06:00:00</field>
      <field name="priority">5</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         ALWAYS-ON JOBS (position management + learning)
    ════════════════════════════════════════════════════════════════════════ -->

    <!-- Every 30 minutes — opens timed entries -->
    <record id="cron_timed_entry" model="ir.cron">
      <field name="name">Trading AI: Timed Entry Check (every 30 min)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_timed_entry()</field>
      <field name="interval_number">30</field>
      <field name="interval_type">minutes</field>
      <field name="active">True</field>
      <field name="nextcall">2026-05-20 06:30:00</field>
      <field name="priority">5</field>
    </record>

    <!-- 16:30 NL (14:30 UTC CEST) — daily position check -->
    <record id="cron_check_positions" model="ir.cron">
      <field name="name">Trading AI: Position Check (16:30 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_check_positions()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-05-20 14:30:00</field>
      <field name="priority">5</field>
    </record>

    <!-- 20:00 NL (18:00 UTC CEST) — post-session rulebook learning -->
    <record id="cron_post_session" model="ir.cron">
      <field name="name">Trading AI: Post-Session Learning (20:00 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_post_session_learning()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-05-20 18:00:00</field>
      <field name="priority">5</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         SESSION-SPECIFIC ANALYSIS CRONS — DISABLED (replaced by Full Scan)
    ════════════════════════════════════════════════════════════════════════ -->

    <record id="cron_daily_analysis" model="ir.cron">
      <field name="name">Trading AI: Pre-Market Analysis (06:00 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_daily_analysis_and_trade()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 04:00:00</field>
      <field name="priority">5</field>
    </record>

    <record id="cron_london_open" model="ir.cron">
      <field name="name">Trading AI: London Open Analysis (09:00 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_london_open()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 07:00:00</field>
      <field name="priority">5</field>
    </record>

    <record id="cron_london_midmorning" model="ir.cron">
      <field name="name">Trading AI: London Mid-Morning (11:00 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_london_midmorning()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 09:00:00</field>
      <field name="priority">6</field>
    </record>

    <record id="cron_pre_ny" model="ir.cron">
      <field name="name">Trading AI: Pre-NY Analysis (13:00 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_pre_ny()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 11:00:00</field>
      <field name="priority">6</field>
    </record>

    <record id="cron_ny_open" model="ir.cron">
      <field name="name">Trading AI: NY Open Analysis (15:00 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_ny_open()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 13:00:00</field>
      <field name="priority">5</field>
    </record>

    <record id="cron_us_market_open" model="ir.cron">
      <field name="name">Trading AI: US Market Open Analysis (15:30 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_us_market_open()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 13:30:00</field>
      <field name="priority">5</field>
    </record>

    <record id="cron_ny_midsession" model="ir.cron">
      <field name="name">Trading AI: NY Mid-Session (17:30 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_ny_midsession()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 15:30:00</field>
      <field name="priority">6</field>
    </record>

    <record id="cron_ny_close_approach" model="ir.cron">
      <field name="name">Trading AI: NY Close Approach (19:00 NL) [DISABLED]</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_ny_close_approach()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">False</field>
      <field name="nextcall">2026-05-20 17:00:00</field>
      <field name="priority">6</field>
    </record>

    <!-- Force-disable legacy session crons regardless of noupdate flags -->
    <function model="trading.automation" name="_disable_legacy_crons"/>

  </data>
</odoo>
