<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- JOB 4: Timed Entry Check — every 30 minutes (the position opener) -->
    <record id="cron_timed_entry" model="ir.cron">
      <field name="name">Trading AI: Timed Entry Check (every 30 min)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_timed_entry()</field>
      <field name="interval_number">30</field>
      <field name="interval_type">minutes</field>
      <field name="active">True</field>
      <field name="nextcall">2026-04-17 06:30:00</field>
      <field name="priority">5</field>
    </record>

    <!-- SESSION 1: Pre-Market — 06:00 NL (04:00 UTC CEST) -->
    <!-- Best for: crypto, AUD/USD, NZD/USD, USD/JPY (Asian session still active) -->
    <record id="cron_daily_analysis" model="ir.cron">
      <field name="name">Trading AI: Pre-Market Analysis (06:00 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_daily_analysis_and_trade()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-04-17 04:00:00</field>
      <field name="priority">5</field>
    </record>

    <!-- SESSION 2: London Open — 09:00 NL (07:00 UTC CEST) -->
    <!-- Best for: EUR/USD, GBP/USD, EUR/GBP, GBP/JPY, XAU/USD, EWG -->
    <record id="cron_london_open" model="ir.cron">
      <field name="name">Trading AI: London Open Analysis (09:00 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_london_open()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-04-17 07:00:00</field>
      <field name="priority">5</field>
    </record>

    <!-- SESSION 3: NY Open / London-NY Overlap — 15:00 NL (13:00 UTC CEST) -->
    <!-- Highest volume — ALL forex majors + US ETFs (SPY/QQQ/DIA) most active -->
    <record id="cron_ny_open" model="ir.cron">
      <field name="name">Trading AI: NY Open Analysis (15:00 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_ny_open()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-04-17 13:00:00</field>
      <field name="priority">5</field>
    </record>


    <!-- SESSION 4: US Market Open — 15:30 NL (13:30 UTC CEST) -->
    <!-- NYSE + NASDAQ open — SPY, QQQ, DIA go live with real exchange data -->
    <record id="cron_us_market_open" model="ir.cron">
      <field name="name">Trading AI: US Market Open Analysis (15:30 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_us_market_open()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-04-17 13:30:00</field>
      <field name="priority">5</field>
    </record>

    <!-- JOB 2: Position Check — 16:30 NL (14:30 UTC CEST) -->
    <record id="cron_check_positions" model="ir.cron">
      <field name="name">Trading AI: Position Check (16:30 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_check_positions()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-04-17 14:30:00</field>
      <field name="priority">5</field>
    </record>

    <!-- JOB 3: Post-Session Learning — 20:00 NL (18:00 UTC CEST) -->
    <record id="cron_post_session" model="ir.cron">
      <field name="name">Trading AI: Post-Session Learning (20:00 NL)</field>
      <field name="model_id" ref="model_trading_automation"/>
      <field name="state">code</field>
      <field name="code">model.cron_post_session_learning()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
      <field name="nextcall">2026-04-17 18:00:00</field>
      <field name="priority">5</field>
    </record>

  </data>
</odoo>
